---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SignupForm from "@/components/auth/SignupForm";
import "@/styles/auth-modern.css";

const publishableKey =
  Astro.locals.runtime?.env.PUBLIC_CLERK_PUBLISHABLE_KEY ??
  import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ??
  null;
---

<BaseLayout title="Create Account - AstroWeb" description="Create your account">
  <div class="auth-page-modern">
    <div class="grid-background"></div>

    <div class="auth-container-modern">
      <a href="/" class="back-link-modern">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path
            d="M19 12H5M5 12l7 7M5 12l7-7"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Back to home
      </a>

      <div class="auth-card-wrapper">
        <SignupForm client:only="react" publishableKey={publishableKey} />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .auth-page-modern {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background: linear-gradient(to bottom, #f0f4f8, #d9e2ec);
    padding: 2rem;
    overflow: hidden;
  }

  .grid-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      linear-gradient(rgba(100, 116, 139, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(100, 116, 139, 0.05) 1px, transparent 1px);
    background-size: 50px 50px;
    z-index: 0;
  }

  .auth-container-modern {
    position: relative;
    z-index: 1;
    max-width: 480px;
    width: 100%;
  }

  .back-link-modern {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #64748b;
    text-decoration: none;
    font-size: 0.875rem;
    margin-bottom: 2rem;
    transition: color 0.2s;
    font-weight: 500;
  }

  .back-link-modern:hover {
    color: #3b82f6;
  }

  .auth-card-wrapper {
    display: flex;
    justify-content: center;
  }

  :global(.auth-unavailable) {
    width: min(100%, 420px);
    padding: 1rem 1.25rem;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.9);
    color: #475569;
    box-shadow:
      0 12px 30px rgba(15, 23, 42, 0.08),
      inset 0 0 0 1px rgba(148, 163, 184, 0.2);
    text-align: center;
  }

  @media (max-width: 640px) {
    .auth-page-modern {
      padding: 1rem;
    }

    .back-link-modern {
      margin-bottom: 1.5rem;
    }
  }
</style>
