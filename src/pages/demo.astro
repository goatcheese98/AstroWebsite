---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, PROJECTS, EXPERIENCES, SKILLS } from "../lib/constants";

const heroTitles = [
  "Business Analyst",
  "Product Engineer",
  "Data Storyteller",
  "Technical Generalist",
];
const topProjects = PROJECTS.slice(0, 3);
const topSkills = [...SKILLS].sort((a, b) => b.level - a.level).slice(0, 8);
const metrics = [
  { label: "Projects Built", value: `${PROJECTS.length}+` },
  { label: "Roles Across Data + Product", value: `${EXPERIENCES.length}` },
  { label: "Core Skills", value: `${topSkills.length}` },
];
---

<BaseLayout
  title="Portfolio Demo"
  description="Experimental standout landing page concept for Rohan Jasani's portfolio."
>
  <div class="demo-root" id="top">
    <div class="demo-progress" id="demo-progress" aria-hidden="true"></div>
    <div class="demo-atmosphere" aria-hidden="true">
      <span class="demo-orb demo-orb--one"></span>
      <span class="demo-orb demo-orb--two"></span>
      <span class="demo-orb demo-orb--three"></span>
      <span class="demo-grid"></span>
    </div>

    <header class="demo-nav container">
      <a href="#top" class="demo-brand">
        <span class="demo-brand__dot"></span>
        <span>{SITE.author}</span>
      </a>
      <nav aria-label="Demo sections">
        <ul class="demo-links">
          <li><a href="#projects">Projects</a></li>
          <li><a href="#skills">Skills</a></li>
          <li><a href="#experience">Experience</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <section class="demo-hero container">
        <div class="demo-hero__text demo-reveal">
          <p class="demo-eyebrow">Portfolio Concept | /demo</p>
          <h1>
            A <span>high-signal</span> digital space for
            <br />
            <strong>{SITE.author}</strong>
          </h1>
          <p class="demo-subtitle">
            <span id="demo-rotating-title" data-titles={JSON.stringify(heroTitles)}
              >{heroTitles[0]}</span
            >
            who turns raw information into product momentum.
          </p>
          <p class="demo-summary">
            Built to feel cinematic and intentional: layered visuals, kinetic
            motion, and a narrative that makes strategy, analytics, and
            execution feel alive.
          </p>
          <div class="demo-hero__actions">
            <a href="#projects" class="demo-btn demo-btn--primary">View Work</a>
            {
              SITE.socialLinks.linkedin && (
                <a
                  href={SITE.socialLinks.linkedin}
                  target="_blank"
                  rel="noopener"
                  class="demo-btn demo-btn--ghost"
                >
                  LinkedIn
                </a>
              )
            }
          </div>
        </div>

        <aside class="demo-panel demo-reveal" aria-label="Highlights panel">
          <div class="demo-panel__halo" aria-hidden="true"></div>
          <p class="demo-panel__label">Live Capability Snapshot</p>
          <div class="demo-panel__avatar">
            <span>RJ</span>
          </div>
          <ul class="demo-metrics">
            {
              metrics.map((metric) => (
                <li>
                  <strong>{metric.value}</strong>
                  <span>{metric.label}</span>
                </li>
              ))
            }
          </ul>
        </aside>
      </section>

      <section class="demo-ticker" aria-label="Skill categories">
        <div class="demo-ticker__track">
          <p>
            Product Strategy | Data Analytics | Experimentation | Visualization |
            Full-Stack Execution | Decision Support | Storytelling |
          </p>
          <p aria-hidden="true">
            Product Strategy | Data Analytics | Experimentation | Visualization |
            Full-Stack Execution | Decision Support | Storytelling |
          </p>
        </div>
      </section>

      <section id="projects" class="demo-section container">
        <div class="demo-heading demo-reveal">
          <p>Selected Projects</p>
          <h2>Work that blends strategy with build speed.</h2>
        </div>
        <div class="demo-projects">
          {
            topProjects.map((project, index) => (
              <article
                class="demo-card demo-card--project demo-reveal"
                style={`--project-accent: ${project.accentColor || "#3458f5"}; --delay: ${index * 0.08}s;`}
              >
                <p class="demo-card__kicker">0{index + 1}</p>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <ul class="demo-tags">
                  {project.tags.slice(0, 4).map((tag) => <li>{tag}</li>)}
                </ul>
                <div class="demo-card__links">
                  {
                    project.codeUrl && (
                      <a href={project.codeUrl} target="_blank" rel="noopener">
                        Code
                      </a>
                    )
                  }
                  {
                    project.demoUrl && (
                      <a
                        href={project.demoUrl}
                        target={project.demoUrl.startsWith("http") ? "_blank" : undefined}
                        rel={project.demoUrl.startsWith("http")
                          ? "noopener"
                          : undefined}
                      >
                        Demo
                      </a>
                    )
                  }
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section id="skills" class="demo-section container">
        <div class="demo-heading demo-reveal">
          <p>Skill Signals</p>
          <h2>Tools that move from insight to execution.</h2>
        </div>

        <div class="demo-skills demo-reveal">
          {
            topSkills.map((skill, index) => (
              <article class="demo-skill" style={`--delay: ${index * 0.05}s;`}>
                <header>
                  <h3>{skill.name}</h3>
                  <span>{skill.level}%</span>
                </header>
                <p>{skill.category}</p>
                <div class="demo-skill__bar" aria-hidden="true">
                  <span style={`width: ${skill.level}%`}></span>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section id="experience" class="demo-section container">
        <div class="demo-heading demo-reveal">
          <p>Experience Arc</p>
          <h2>Cross-functional roles with measurable outcomes.</h2>
        </div>
        <div class="demo-timeline">
          {
            EXPERIENCES.map((exp, index) => (
              <article class="demo-card demo-card--exp demo-reveal" style={`--delay: ${index * 0.1}s;`}>
                <p class="demo-card__kicker">{exp.period}</p>
                <h3>{exp.role}</h3>
                <p class="demo-exp__company">{exp.company}</p>
                <p>{exp.description}</p>
                <ul>
                  {exp.highlights.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section id="contact" class="demo-contact container demo-reveal">
        <p>Open to internships, analytics roles, and ambitious build projects.</p>
        <h2>Let's design something with real business impact.</h2>
        <div class="demo-contact__actions">
          {
            SITE.socialLinks.email && (
              <a href={SITE.socialLinks.email} class="demo-btn demo-btn--primary">
                Email Me
              </a>
            )
          }
          {
            SITE.socialLinks.github && (
              <a
                href={SITE.socialLinks.github}
                target="_blank"
                rel="noopener"
                class="demo-btn demo-btn--ghost"
              >
                GitHub
              </a>
            )
          }
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const titleEl = document.querySelector("#demo-rotating-title");
  const titles = JSON.parse(titleEl?.getAttribute("data-titles") || "[]");

  if (titleEl && !reduceMotion) {
    const fallbackTitles = [
      "Business Analyst",
      "Product Engineer",
      "Data Storyteller",
      "Technical Generalist",
    ];
    const activeTitles = titles.length > 0 ? titles : fallbackTitles;
    let idx = 0;
    setInterval(() => {
      idx = (idx + 1) % activeTitles.length;
      titleEl.textContent = activeTitles[idx];
    }, 2600);
  }

  const progress = document.querySelector("#demo-progress");
  const updateProgress = () => {
    const doc = document.documentElement;
    const maxScroll = doc.scrollHeight - window.innerHeight;
    const ratio = maxScroll > 0 ? window.scrollY / maxScroll : 0;
    if (progress) progress.style.transform = `scaleX(${ratio})`;
  };
  updateProgress();
  window.addEventListener("scroll", updateProgress, { passive: true });

  if (!reduceMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 },
    );
    document.querySelectorAll(".demo-reveal").forEach((el) => observer.observe(el));

    const root = document.querySelector(".demo-root");
    window.addEventListener(
      "pointermove",
      (event) => {
        if (!root) return;
        const x = (event.clientX / window.innerWidth) * 100;
        const y = (event.clientY / window.innerHeight) * 100;
        root.style.setProperty("--pointer-x", `${x}%`);
        root.style.setProperty("--pointer-y", `${y}%`);
      },
      { passive: true },
    );
  } else {
    document.querySelectorAll(".demo-reveal").forEach((el) =>
      el.classList.add("is-visible"),
    );
  }
</script>

<style>
  @font-face {
    font-family: "DemoDisplay";
    src: url("/fonts/Virgil.woff2") format("woff2");
    font-display: swap;
  }

  @font-face {
    font-family: "DemoText";
    src: url("/fonts/Excalifont-Regular.woff2") format("woff2");
    font-display: swap;
  }

  @font-face {
    font-family: "DemoMono";
    src: url("/fonts/CascadiaCode-Regular.woff2") format("woff2");
    font-display: swap;
  }

  :global(body) {
    background:
      radial-gradient(circle at 15% 15%, rgba(255, 163, 127, 0.2), transparent 35%),
      radial-gradient(circle at 80% 10%, rgba(103, 170, 255, 0.2), transparent 40%),
      radial-gradient(circle at 50% 100%, rgba(131, 226, 188, 0.2), transparent 45%),
      #fbf8f2;
  }

  :global(body)::before {
    opacity: 0.22;
  }

  .demo-root {
    --demo-border: rgba(24, 26, 38, 0.14);
    --demo-text: #161925;
    --demo-text-soft: #44516f;
    --demo-surface: rgba(255, 255, 255, 0.72);
    --demo-highlight: #ff6b38;
    --demo-highlight-alt: #426cff;
    --pointer-x: 50%;
    --pointer-y: 30%;
    color: var(--demo-text);
    font-family: "DemoText", "Trebuchet MS", sans-serif;
    position: relative;
    overflow: clip;
    padding-bottom: clamp(4rem, 7vw, 7rem);
  }

  .demo-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, #ff6b38, #426cff, #00a86b);
    transform-origin: left center;
    transform: scaleX(0);
    z-index: 300;
  }

  .demo-atmosphere {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }

  .demo-grid {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
        to right,
        rgba(50, 58, 83, 0.06) 1px,
        transparent 1px
      ),
      linear-gradient(to bottom, rgba(50, 58, 83, 0.06) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: radial-gradient(circle at center, black 35%, transparent 80%);
  }

  .demo-orb {
    position: absolute;
    border-radius: 999px;
    filter: blur(0.5px);
    animation: drift 16s ease-in-out infinite;
  }

  .demo-orb--one {
    width: clamp(14rem, 35vw, 28rem);
    height: clamp(14rem, 35vw, 28rem);
    background: radial-gradient(circle, rgba(255, 107, 56, 0.22), transparent 66%);
    left: calc(var(--pointer-x) - 18%);
    top: calc(var(--pointer-y) - 20%);
  }

  .demo-orb--two {
    width: clamp(18rem, 42vw, 34rem);
    height: clamp(18rem, 42vw, 34rem);
    background: radial-gradient(circle, rgba(66, 108, 255, 0.18), transparent 68%);
    right: -10rem;
    top: 4rem;
    animation-delay: -5s;
  }

  .demo-orb--three {
    width: clamp(15rem, 32vw, 26rem);
    height: clamp(15rem, 32vw, 26rem);
    background: radial-gradient(circle, rgba(0, 168, 107, 0.15), transparent 70%);
    left: -7rem;
    bottom: 10%;
    animation-delay: -8s;
  }

  .demo-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    position: sticky;
    top: 0;
    z-index: 120;
    padding-top: var(--space-sm);
    padding-bottom: var(--space-sm);
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    backdrop-filter: blur(16px);
  }

  .demo-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: "DemoDisplay", "Marker Felt", cursive;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    color: var(--demo-text);
    letter-spacing: 0.02em;
  }

  .demo-brand__dot {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #ff6b38, #426cff);
    box-shadow: 0 0 0 6px rgba(255, 107, 56, 0.18);
  }

  .demo-links {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    list-style: none;
    padding: 0.25rem;
    border: 1px solid var(--demo-border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.68);
  }

  .demo-links a {
    display: inline-flex;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    color: var(--demo-text-soft);
    font-size: 0.9rem;
    font-family: "DemoMono", "Courier New", monospace;
    transition: all 200ms ease;
  }

  .demo-links a:hover {
    color: #fff;
    background: linear-gradient(135deg, #426cff, #00a86b);
  }

  .demo-hero {
    display: grid;
    grid-template-columns: 1.1fr 0.85fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
    min-height: min(78vh, 780px);
    padding-top: clamp(1rem, 4vw, 3rem);
  }

  .demo-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.74rem;
    font-family: "DemoMono", "Courier New", monospace;
    color: var(--demo-text-soft);
    margin-bottom: 1rem;
  }

  .demo-eyebrow::before {
    content: "";
    width: 2.2rem;
    height: 1px;
    background: linear-gradient(90deg, #ff6b38, transparent);
  }

  .demo-hero h1 {
    font-family: "DemoDisplay", "Comic Sans MS", cursive;
    font-size: clamp(2.1rem, 6vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .demo-hero h1 span {
    color: var(--demo-highlight-alt);
  }

  .demo-hero h1 strong {
    color: #ff6b38;
    font-weight: 400;
  }

  .demo-subtitle {
    font-size: clamp(1.1rem, 2.2vw, 1.55rem);
    line-height: 1.35;
    color: #2f3f60;
    margin-bottom: 1rem;
    max-width: 34ch;
  }

  #demo-rotating-title {
    background: linear-gradient(100deg, #426cff, #00a86b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
    min-width: 13ch;
    font-family: "DemoDisplay", "Comic Sans MS", cursive;
  }

  .demo-summary {
    color: var(--demo-text-soft);
    font-size: 1.06rem;
    max-width: 55ch;
    margin-bottom: 1.6rem;
  }

  .demo-hero__actions,
  .demo-contact__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .demo-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 1.05rem;
    border-radius: 0.8rem;
    border: 1px solid transparent;
    font-family: "DemoMono", "Courier New", monospace;
    font-size: 0.9rem;
    transition: transform 180ms ease, box-shadow 180ms ease, background 200ms ease;
  }

  .demo-btn:hover {
    transform: translateY(-2px);
  }

  .demo-btn--primary {
    color: #fff;
    background: linear-gradient(135deg, #ff6b38, #426cff);
    box-shadow: 0 14px 28px rgba(64, 94, 206, 0.23);
  }

  .demo-btn--ghost {
    color: var(--demo-text);
    border-color: var(--demo-border);
    background: rgba(255, 255, 255, 0.66);
  }

  .demo-panel {
    position: relative;
    border: 1px solid var(--demo-border);
    border-radius: 1.3rem;
    padding: 1.2rem;
    background: var(--demo-surface);
    box-shadow: 0 30px 60px rgba(28, 37, 66, 0.12);
    isolation: isolate;
  }

  .demo-panel__halo {
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    z-index: -1;
    background: conic-gradient(
      from 90deg,
      rgba(255, 107, 56, 0.26),
      rgba(66, 108, 255, 0.26),
      rgba(0, 168, 107, 0.2),
      rgba(255, 107, 56, 0.26)
    );
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: xor;
    padding: 1px;
  }

  .demo-panel__label {
    font-family: "DemoMono", "Courier New", monospace;
    font-size: 0.76rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #5f6d8f;
    margin-bottom: 1rem;
  }

  .demo-panel__avatar {
    width: clamp(4rem, 10vw, 7rem);
    aspect-ratio: 1;
    border-radius: 1rem;
    margin-bottom: 1rem;
    background: linear-gradient(145deg, #426cff, #00a86b);
    display: grid;
    place-items: center;
    color: #fff;
    font-family: "DemoDisplay", "Comic Sans MS", cursive;
    font-size: clamp(1.6rem, 3.5vw, 2.8rem);
    box-shadow: 0 14px 28px rgba(34, 59, 166, 0.3);
  }

  .demo-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
    list-style: none;
  }

  .demo-metrics li {
    border: 1px solid rgba(50, 58, 83, 0.14);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.8);
    padding: 0.65rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .demo-metrics strong {
    font-family: "DemoMono", "Courier New", monospace;
    font-size: 1rem;
    color: #1d2d5f;
  }

  .demo-metrics span {
    font-size: 0.8rem;
    color: #58678d;
    line-height: 1.2;
  }

  .demo-ticker {
    margin-top: clamp(1.3rem, 4vw, 3rem);
    margin-bottom: clamp(2rem, 5vw, 4.5rem);
    border-block: 1px solid rgba(40, 48, 74, 0.14);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.6);
  }

  .demo-ticker__track {
    display: flex;
    width: max-content;
    animation: marquee 26s linear infinite;
    font-family: "DemoMono", "Courier New", monospace;
    font-size: 0.86rem;
    letter-spacing: 0.04em;
    color: #4f5d80;
  }

  .demo-ticker__track p {
    padding: 0.9rem 1rem;
    white-space: nowrap;
  }

  .demo-section {
    margin-top: clamp(1.8rem, 5vw, 5rem);
  }

  .demo-heading p {
    font-family: "DemoMono", "Courier New", monospace;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    font-size: 0.72rem;
    color: #5f6d8f;
    margin-bottom: 0.45rem;
  }

  .demo-heading h2 {
    font-family: "DemoDisplay", "Comic Sans MS", cursive;
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    line-height: 1.08;
    max-width: 24ch;
  }

  .demo-projects {
    margin-top: 1.2rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .demo-card {
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid var(--demo-border);
    border-radius: 1rem;
    padding: 1rem;
    transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
  }

  .demo-card:hover {
    transform: translateY(-6px) rotate(-0.5deg);
    box-shadow: 0 24px 36px rgba(24, 35, 68, 0.15);
    border-color: rgba(66, 108, 255, 0.35);
  }

  .demo-card--project {
    border-top: 3px solid var(--project-accent, #426cff);
  }

  .demo-card__kicker {
    font-family: "DemoMono", "Courier New", monospace;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    color: #5f6d8f;
    margin-bottom: 0.5rem;
  }

  .demo-card h3,
  .demo-skill h3 {
    font-family: "DemoDisplay", "Comic Sans MS", cursive;
    font-size: 1.3rem;
    margin-bottom: 0.45rem;
  }

  .demo-card p {
    color: var(--demo-text-soft);
    font-size: 0.95rem;
    margin-bottom: 0.65rem;
  }

  .demo-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
    list-style: none;
  }

  .demo-tags li {
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    border: 1px solid rgba(35, 44, 68, 0.17);
    font-size: 0.7rem;
    color: #405173;
    font-family: "DemoMono", "Courier New", monospace;
  }

  .demo-card__links {
    display: flex;
    gap: 0.6rem;
  }

  .demo-card__links a {
    font-size: 0.82rem;
    font-family: "DemoMono", "Courier New", monospace;
    padding: 0.34rem 0.55rem;
    border-radius: 0.5rem;
    color: #fff;
    background: #2d4fa5;
  }

  .demo-skills {
    margin-top: 1.2rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .demo-skill {
    background: rgba(255, 255, 255, 0.76);
    border-radius: 0.85rem;
    border: 1px solid var(--demo-border);
    padding: 0.9rem;
  }

  .demo-skill header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .demo-skill header span {
    font-family: "DemoMono", "Courier New", monospace;
    color: #3352ad;
    font-size: 0.84rem;
