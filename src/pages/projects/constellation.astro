---
import PageLayout from "../../layouts/PageLayout.astro";

const title = "Methanex HR Dashboard";
const description = "An interactive HR dashboard built for the MBAN Hackathon to analyze and visualize employee data, helping drive strategic workforce decisions.";
---

<PageLayout title={title} description={description}>
  <section class="section-gap" style="min-height: 60vh; display: flex; align-items: center; justify-content: center; text-align: center;">
    <div class="container">
      <h1 style="font-family: var(--font-hand); font-size: var(--text-2xl); margin-bottom: var(--space-md);">
        Redirecting to Methanex HR Dashboard...
      </h1>
      <p style="color: var(--color-text-muted); margin-bottom: var(--space-lg);">
        You are being redirected to the live project.
      </p>
      <p style="font-size: var(--text-sm);">
        If you are not redirected automatically,
        <a href="https://career-constellation.pages.dev/dashboard" style="color: var(--color-accent); text-decoration: underline;">
          click here
        </a>.
      </p>
    </div>
  </section>
</PageLayout>

<script>
  // Redirect after a short delay so the URL is registered by the browser/LinkedIn
  setTimeout(() => {
    window.location.href = "https://career-constellation.pages.dev/dashboard";
  }, 1500);
</script>
