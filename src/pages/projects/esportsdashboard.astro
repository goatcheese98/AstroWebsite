---
import PageLayout from "../../layouts/PageLayout.astro";

const title = "ALGS Esports Performance Dashboard";
const description = "Interactive dashboard for ALGS player and team performance, powered by a Python data pipeline for clean, queryable tournament analytics.";
const DEST = "https://algs-championship-viz.pages.dev/";
---

<PageLayout title={title} description={description}>
  <section class="redirect-section">
    <div class="container">
      <div class="redirect-card">
        <div class="countdown-ring" aria-hidden="true">
          <svg viewBox="0 0 56 56" fill="none">
            <circle class="ring-track" cx="28" cy="28" r="24" stroke-width="3"/>
            <circle class="ring-progress" cx="28" cy="28" r="24" stroke-width="3"
              stroke-dasharray="150.796" stroke-dashoffset="0"/>
          </svg>
          <span class="ring-number" id="countdown-number">5</span>
        </div>
        <h1 class="redirect-title">Redirecting to ALGS Esports Dashboard…</h1>
        <p class="redirect-sub">You'll be taken to the live project in <strong id="countdown-label">5</strong> seconds.</p>
        <p class="redirect-fallback">
          Not redirected? <a href={DEST}>Click here</a>.
        </p>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .redirect-section {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .redirect-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    background: var(--color-surface);
    border: 2px solid var(--color-stroke);
    border-radius: var(--radius-md);
    box-shadow: 6px 6px 0 var(--color-stroke);
    padding: var(--space-2xl) clamp(var(--space-lg), 8vw, var(--space-3xl));
  }

  .countdown-ring {
    position: relative;
    width: 88px;
    height: 88px;
  }

  .countdown-ring svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .ring-track { stroke: var(--color-stroke-muted); }
  .ring-progress {
    stroke: var(--color-accent);
    stroke-linecap: round;
    transition: stroke-dashoffset 1s linear;
  }

  .ring-number {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-hand);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text);
  }

  .redirect-title {
    font-family: var(--font-hand);
    font-size: var(--text-2xl);
    color: var(--color-text);
    margin: 0;
  }

  .redirect-sub {
    color: var(--color-text-muted);
    margin: 0;
  }

  .redirect-fallback {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .redirect-fallback a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: reduce) {
    .ring-progress { transition: none; }
  }
</style>

<script define:vars={{ DEST }}>
  const DURATION = 5;
  const CIRCUMFERENCE = 150.796;

  const numberEl = document.getElementById("countdown-number");
  const labelEl = document.getElementById("countdown-label");
  const progress = document.querySelector(".ring-progress");

  let remaining = DURATION;

  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      if (progress) progress.style.strokeDashoffset = String(CIRCUMFERENCE);
    });
  });

  const tick = setInterval(() => {
    remaining -= 1;
    if (numberEl) numberEl.textContent = String(remaining);
    if (labelEl) labelEl.textContent = String(remaining);
    if (remaining <= 0) {
      clearInterval(tick);
      window.location.href = DEST;
    }
  }, 1000);
</script>
