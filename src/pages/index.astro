---
import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/sections/Hero.astro";
import Projects from "../components/sections/Projects.astro";
import Experience from "../components/sections/Experience.astro";
import BentoSkills from "../components/islands/BentoSkills.svelte";
import SectionHeader from "../components/ui/SectionHeader.astro";
import { PROJECTS, SKILLS } from "../lib/constants";

const marqueeItems = [
  ...new Set([
    ...SKILLS.map((skill) => skill.category),
    ...PROJECTS.flatMap((project) => project.tags),
  ]),
].slice(0, 14);
---

<PageLayout title="Home">
  <div class="landing-page" id="landing-page">
    <div class="landing-progress" id="landing-progress" aria-hidden="true"></div>
    <div class="landing-glow" aria-hidden="true"></div>

    <Hero />

    <section class="landing-marquee" aria-label="Portfolio highlights">
      <div class="landing-marquee__track">
        <ul class="landing-marquee__list">
          {marqueeItems.map((item) => <li>{item}</li>)}
        </ul>
        <ul class="landing-marquee__list" aria-hidden="true">
          {marqueeItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <Projects />
    <Experience />

    <section class="skills section-gap" id="skills" aria-label="Skills">
      <div class="container">
        <SectionHeader
          title="Skills & Expertise"
          subtitle="A generalist's toolkit spanning data, technology, and strategy"
        />
        <BentoSkills client:load />
      </div>
    </section>
  </div>
</PageLayout>

<script>
  import { annotate } from "rough-notation";

  function initLandingPage() {
    const existingCleanup = (window as Window & { __landingCleanup?: () => void })
      .__landingCleanup;
    if (existingCleanup) existingCleanup();

    document.body.classList.add("landing-grid-mode");

    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const style = getComputedStyle(document.documentElement);
    const accentColor = style.getPropertyValue("--color-accent").trim();

    const el = document.querySelector("#hero-title");
    if (el && !reducedMotion) {
      const annotation = annotate(el as HTMLElement, {
        type: "underline",
        color: accentColor,
        strokeWidth: 2,
        padding: 4,
      });
      annotation.show();
    }

    const landingEl = document.querySelector("#landing-page") as HTMLElement | null;
    const progressEl = document.querySelector("#landing-progress") as HTMLElement | null;

    const updateProgress = () => {
      if (!progressEl) return;
      const doc = document.documentElement;
      const maxScroll = doc.scrollHeight - window.innerHeight;
      const ratio = maxScroll > 0 ? window.scrollY / maxScroll : 0;
      progressEl.style.transform = `scaleX(${ratio})`;
    };

    let pointerFrame = 0;
    const updateGlow = (event: PointerEvent) => {
      if (!landingEl || reducedMotion) return;
      if (pointerFrame) cancelAnimationFrame(pointerFrame);
      pointerFrame = requestAnimationFrame(() => {
        const x = (event.clientX / window.innerWidth) * 100;
        const y = (event.clientY / window.innerHeight) * 100;
        landingEl.style.setProperty("--landing-mouse-x", `${x}%`);
        landingEl.style.setProperty("--landing-mouse-y", `${y}%`);
      });
    };

    updateProgress();
    window.addEventListener("scroll", updateProgress, { passive: true });
    window.addEventListener("resize", updateProgress);
    window.addEventListener("pointermove", updateGlow, { passive: true });

    const cleanup = () => {
      window.removeEventListener("scroll", updateProgress);
      window.removeEventListener("resize", updateProgress);
      window.removeEventListener("pointermove", updateGlow);
      document.body.classList.remove("landing-grid-mode");
    };

    (window as Window & { __landingCleanup?: () => void }).__landingCleanup =
      cleanup;
  }

  // Run on page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLandingPage);
  } else {
    initLandingPage();
  }

  document.addEventListener("astro:page-load", initLandingPage);
  document.addEventListener("astro:before-swap", () => {
    const cleanup = (window as Window & { __landingCleanup?: () => void })
      .__landingCleanup;
    if (cleanup) cleanup();
  });
</script>

<style>
  .landing-page {
    --landing-mouse-x: 48%;
    --landing-mouse-y: 16%;
    position: relative;
  }

  .landing-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    transform-origin: left center;
    transform: scaleX(0);
    z-index: 240;
    background: linear-gradient(
      90deg,
      var(--color-accent),
      var(--color-gradient-end),
      var(--color-accent)
    );
  }

  .landing-glow {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    background: radial-gradient(
      circle 480px at var(--landing-mouse-x) var(--landing-mouse-y),
      rgba(59, 130, 246, 0.07),
      transparent 72%
    );
  }

  .landing-marquee {
    margin-block: var(--space-sm) 0;
    background: #0d0d12;
    overflow: hidden;
    position: relative;
  }

  .landing-marquee::before,
  .landing-marquee::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 60px;
    z-index: 2;
    pointer-events: none;
  }

  .landing-marquee::before {
    left: 0;
    background: linear-gradient(90deg, #0d0d12, transparent);
  }

  .landing-marquee::after {
    right: 0;
    background: linear-gradient(-90deg, #0d0d12, transparent);
  }

  .landing-marquee__track {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: landing-marquee 32s linear infinite;
  }

  .landing-marquee__list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0.72rem 0.5rem;
  }

  .landing-marquee__list li {
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: #ffd600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.26rem 1rem;
    border: none;
    border-radius: 0;
    background: transparent;
  }

  .landing-marquee__list li::after {
    content: "✦";
    margin-left: 1rem;
    color: #ff5c3a;
    opacity: 0.8;
  }

  @keyframes landing-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .landing-page :global(.section-gap) {
    padding-block: clamp(1.5rem, 3.8vw, 2.5rem);
  }


  .landing-page :global(.section-header) {
    margin-bottom: var(--space-lg);
  }

  /* ── Section color zones ── */
  .landing-page :global(#projects),
  .landing-page :global(#experience),
  .landing-page :global(#skills) {
    position: relative;
  }

  .landing-page :global(#projects)  { background: rgba(180, 230, 20,  0.07); }
  .landing-page :global(#experience){ background: rgba(255, 210,  0,  0.07); }
  .landing-page :global(#skills)    { background: rgba(255,  80, 40,  0.06); }

  :global([data-theme="dark"]) .landing-page :global(#projects)  { background: rgba(180, 230, 20,  0.06); }
  :global([data-theme="dark"]) .landing-page :global(#experience){ background: rgba(255, 210,  0,  0.06); }
  :global([data-theme="dark"]) .landing-page :global(#skills)    { background: rgba(255,  80, 40,  0.05); }

  /* ── Animated wave edges via pseudo-elements ──
     Only background-position is animated — GPU-composited, zero layout cost.
     A bright spotlight travels along a 4px strip at top and bottom,
     creating a slow shimmer that reads as a living border wave.           */

  .landing-page :global(#projects)::before,
  .landing-page :global(#projects)::after,
  .landing-page :global(#experience)::before,
  .landing-page :global(#experience)::after,
  .landing-page :global(#skills)::before,
  .landing-page :global(#skills)::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 4px;
    background-size: 300% 100%;
    pointer-events: none;
    z-index: 2;
  }

  .landing-page :global(#projects)::before  { top: 0; }
  .landing-page :global(#projects)::after   { bottom: 0; }
  .landing-page :global(#experience)::before{ top: 0; }
  .landing-page :global(#experience)::after { bottom: 0; }
  .landing-page :global(#skills)::before    { top: 0; }
  .landing-page :global(#skills)::after     { bottom: 0; }

  /* Projects top — lime only (nothing above) */
  .landing-page :global(#projects)::before {
    background-image: linear-gradient(
      to right,
      transparent 0%,
      rgba(180, 230, 20, 0.55) 20%,
      rgba(220, 255, 60, 0.95) 50%,
      rgba(180, 230, 20, 0.55) 80%,
      transparent 100%
    );
    animation: wave-edge 7s ease-in-out infinite alternate;
  }

  /* Projects bottom + Experience top — lime → yellow blend */
  .landing-page :global(#projects)::after,
  .landing-page :global(#experience)::before {
    background-image: linear-gradient(
      to right,
      transparent 0%,
      rgba(195, 240, 10, 0.6) 15%,
      rgba(215, 252, 20, 0.95) 35%,
      rgba(255, 228, 0, 0.95) 65%,
      rgba(255, 210, 0, 0.6) 85%,
      transparent 100%
    );
    animation: wave-edge 7.5s ease-in-out infinite alternate;
    animation-delay: -1.5s;
  }

  /* Experience bottom + Skills top — yellow → coral blend */
  .landing-page :global(#experience)::after,
  .landing-page :global(#skills)::before {
    background-image: linear-gradient(
      to right,
      transparent 0%,
      rgba(255, 220, 0, 0.6) 15%,
      rgba(255, 235, 30, 0.95) 35%,
      rgba(255, 100, 50, 0.95) 65%,
      rgba(255, 80, 40, 0.6) 85%,
      transparent 100%
    );
    animation: wave-edge 7s ease-in-out infinite alternate;
    animation-delay: -2.5s;
  }

  /* Skills bottom — coral only */
  .landing-page :global(#skills)::after {
    background-image: linear-gradient(
      to right,
      transparent 0%,
      rgba(255, 80, 40, 0.50) 20%,
      rgba(255, 130, 90, 0.90) 50%,
      rgba(255, 80, 40, 0.50) 80%,
      transparent 100%
    );
    animation: wave-edge 6s ease-in-out infinite alternate;
    animation-delay: -1.5s;
  }

  @keyframes wave-edge {
    from { background-position:   0% 0; }
    to   { background-position: 100% 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-page :global(#projects)::before,
    .landing-page :global(#projects)::after,
    .landing-page :global(#experience)::before,
    .landing-page :global(#experience)::after,
    .landing-page :global(#skills)::before,
    .landing-page :global(#skills)::after {
      animation: none;
      background-position: 50% 0;
    }
  }

  :global(body.landing-grid-mode)::before {
    background-image:
      linear-gradient(
        to right,
        rgba(var(--dot-color-rgb), 0.22) 1px,
        transparent 1px
      ),
      linear-gradient(
        to bottom,
        rgba(var(--dot-color-rgb), 0.22) 1px,
        transparent 1px
      );
    background-size: 34px 34px;
    opacity: 0.35;
  }

  @media (max-width: 900px) {
    .landing-marquee__list {
      padding: 0.62rem 0.45rem;
      gap: 0.45rem;
    }

    .landing-page :global(.section-gap) {
      padding-block: clamp(1.25rem, 5vw, 1.8rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-marquee__track {
      animation: none;
      transform: translateX(0);
    }

    .landing-glow {
      display: none;
    }
  }
</style>
