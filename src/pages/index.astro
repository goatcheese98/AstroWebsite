---
import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/sections/Hero.astro";
import Projects from "../components/sections/Projects.astro";
import Experience from "../components/sections/Experience.astro";
import BentoSkills from "../components/islands/BentoSkills.svelte";
import SectionHeader from "../components/ui/SectionHeader.astro";
import { PROJECTS, SKILLS } from "../lib/constants";

const marqueeItems = [
  ...new Set([
    ...SKILLS.map((skill) => skill.category),
    ...PROJECTS.flatMap((project) => project.tags),
  ]),
].slice(0, 14);
---

<PageLayout title="Home">
  <canvas id="rough-bg-canvas" aria-hidden="true"></canvas>
  <div class="landing-page" id="landing-page">
    <div class="landing-progress" id="landing-progress" aria-hidden="true"></div>
    <div class="landing-glow" aria-hidden="true"></div>

    <Hero />

    <Experience />
    <Projects />

    <section class="skills section-gap" id="skills" aria-label="Skills">
      <div class="container">
        <SectionHeader
          title="Skills & Expertise"
          subtitle="A generalist's toolkit spanning data, technology, and strategy"
        />
        <BentoSkills client:load />
      </div>
    </section>

    <section class="landing-marquee" aria-label="Portfolio highlights" aria-hidden="true">
      <div class="landing-marquee__track">
        <ul class="landing-marquee__list">
          {marqueeItems.map((item) => <li>{item}</li>)}
        </ul>
        <ul class="landing-marquee__list" aria-hidden="true">
          {marqueeItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>
  </div>
</PageLayout>

<script>
  function initLandingPage() {
    const existingCleanup = (window as Window & { __landingCleanup?: () => void })
      .__landingCleanup;
    if (existingCleanup) existingCleanup();

    const progressEl = document.querySelector("#landing-progress") as HTMLElement | null;

    const landingEl = document.querySelector("#landing-page") as HTMLElement | null;
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let pointerFrame = 0;
    const updateGlow = (event: PointerEvent) => {
      if (!landingEl || reducedMotion) return;
      if (pointerFrame) cancelAnimationFrame(pointerFrame);
      pointerFrame = requestAnimationFrame(() => {
        const viewportWidth = window.innerWidth;
        const viewportHeight = window.innerHeight;
        const x = (event.clientX / viewportWidth) * 100;
        const y = (event.clientY / viewportHeight) * 100;

        landingEl.style.setProperty("--glow-x", `${x}%`);
        landingEl.style.setProperty("--glow-y", `${y}%`);
      });
    };
    window.addEventListener("pointermove", updateGlow, { passive: true });

    const updateProgress = () => {
      if (!progressEl) return;
      const doc = document.documentElement;
      const maxScroll = doc.scrollHeight - window.innerHeight;
      const ratio = maxScroll > 0 ? window.scrollY / maxScroll : 0;
      progressEl.style.transform = `scaleX(${ratio})`;
    };

    updateProgress();
    window.addEventListener("scroll", updateProgress, { passive: true });
    window.addEventListener("resize", updateProgress, { passive: true });

    (window as Window & { __landingCleanup?: () => void }).__landingCleanup = () => {
      window.removeEventListener("scroll", updateProgress);
      window.removeEventListener("resize", updateProgress);
      window.removeEventListener("pointermove", updateGlow);
    };
  }

  // ── Rough.js graph-paper background ───────────────────────────────────────
  async function initRoughBg() {
    const canvas = document.getElementById("rough-bg-canvas") as HTMLCanvasElement | null;
    if (!canvas) return;

    let rough: typeof import("roughjs")["default"];
    try {
      ({ default: rough } = await import("roughjs"));
    } catch {
      return;
    }

    const GRID = 52;
    const MAJOR_EVERY = 4;

    function draw() {
      const w = window.innerWidth;
      const h = window.innerHeight;
      canvas!.width = w;
      canvas!.height = h;

      const isDark = document.documentElement.dataset.theme === "dark";
      const rgb = isDark ? "255,255,255" : "13,13,18";
      const rc = rough.canvas(canvas!);

      for (let y = 0; y <= h; y += GRID) {
        const isMajor = Math.round(y / GRID) % MAJOR_EVERY === 0;
        rc.line(0, y, w, y, {
          stroke: `rgba(${rgb},${isMajor ? 0.072 : 0.030})`,
          roughness: 0.45,
          strokeWidth: isMajor ? 1.1 : 0.65,
          bowing: 0.4,
        });
      }

      for (let x = 0; x <= w; x += GRID) {
        const isMajor = Math.round(x / GRID) % MAJOR_EVERY === 0;
        rc.line(x, 0, x, h, {
          stroke: `rgba(${rgb},${isMajor ? 0.072 : 0.030})`,
          roughness: 0.45,
          strokeWidth: isMajor ? 1.1 : 0.65,
          bowing: 0.4,
        });
      }
    }

    draw();

    let resizeTimer: ReturnType<typeof setTimeout>;
    const onResize = () => { clearTimeout(resizeTimer); resizeTimer = setTimeout(draw, 160); };
    window.addEventListener("resize", onResize, { passive: true });

    const mo = new MutationObserver(draw);
    mo.observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });

    (window as Window & { __roughBgCleanup?: () => void }).__roughBgCleanup?.();
    (window as Window & { __roughBgCleanup?: () => void }).__roughBgCleanup = () => {
      mo.disconnect();
      clearTimeout(resizeTimer);
      window.removeEventListener("resize", onResize);
    };
  }

  function init() {
    initLandingPage();
    initRoughBg();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-swap", () => {
    (window as Window & { __landingCleanup?: () => void }).__landingCleanup?.();
    (window as Window & { __roughBgCleanup?: () => void }).__roughBgCleanup?.();
  });
</script>

<style>
  #rough-bg-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }

  .landing-page {
    --glow-x: 50%;
    --glow-y: 20%;
    --landing-glow-primary-rgb: 255, 214, 0;   /* yellow */
    --landing-glow-secondary-rgb: 251, 191, 36; /* amber */
    --landing-glow-tertiary-rgb: 245, 158, 11;  /* warm amber */
    --landing-glow-primary-alpha: 0.2;
    --landing-glow-secondary-alpha: 0.15;
    --landing-glow-tertiary-alpha: 0.12;
    position: relative;
    background: transparent;
  }

  .landing-glow {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 12;
    will-change: background;
    mix-blend-mode: screen;
    background:
      radial-gradient(
        circle 390px at var(--glow-x) var(--glow-y),
        rgba(var(--landing-glow-primary-rgb), var(--landing-glow-primary-alpha)),
        rgba(var(--landing-glow-secondary-rgb), calc(var(--landing-glow-secondary-alpha) * 0.75)) 52%,
        transparent 72%
      ),
      radial-gradient(
        circle 200px at var(--glow-x) var(--glow-y),
        rgba(var(--landing-glow-tertiary-rgb), var(--landing-glow-tertiary-alpha)),
        transparent 74%
      );
  }

  :global([data-theme="dark"]) .landing-page {
    --landing-glow-primary-rgb: 249, 115, 22;  /* orange */
    --landing-glow-secondary-rgb: 190, 24, 93; /* rose red */
    --landing-glow-tertiary-rgb: 147, 51, 234; /* purple */
    --landing-glow-primary-alpha: 0.25;
    --landing-glow-secondary-alpha: 0.18;
    --landing-glow-tertiary-alpha: 0.15;
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-glow {
      display: none;
    }
  }

  .landing-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    transform-origin: left center;
    transform: scaleX(0);
    z-index: 240;
    background: linear-gradient(
      90deg,
      var(--color-accent),
      var(--color-gradient-end),
      var(--color-accent)
    );
  }

  /* ── Match footer aesthetic: dark headings, yellow accent ── */

  /* Section headers: dark instead of blue gradient */
  .landing-page :global(.gradient-text) {
    background: none;
    -webkit-background-clip: unset;
    background-clip: unset;
    -webkit-text-fill-color: #0d0d12;
    color: #0d0d12;
  }

  :global([data-theme="dark"]) .landing-page :global(.gradient-text) {
    -webkit-text-fill-color: #f5f5f5;
    color: #f5f5f5;
  }

  /* Section header underline bar: yellow instead of blue */
  .landing-page :global(.section-header__line) {
    background: #ffd600;
    filter: none;
  }

  .landing-page :global(.section-gap) {
    padding-block: clamp(1.5rem, 3.8vw, 2.5rem);
  }

  .landing-page :global(.section-header) {
    margin-bottom: var(--space-lg);
  }

  /* ── Marquee ticker (bottom) ── */
  .landing-marquee {
    background: #0d0d12;
    overflow: hidden;
    position: relative;
  }

  .landing-marquee::before,
  .landing-marquee::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 60px;
    z-index: 2;
    pointer-events: none;
  }

  .landing-marquee::before {
    left: 0;
    background: linear-gradient(90deg, #0d0d12, transparent);
  }

  .landing-marquee::after {
    right: 0;
    background: linear-gradient(-90deg, #0d0d12, transparent);
  }

  .landing-marquee__track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: landing-marquee 32s linear infinite;
  }

  .landing-marquee__list {
    list-style: none;
    display: flex;
    align-items: center;
    padding: 0.72rem 0.5rem;
  }

  .landing-marquee__list li {
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: #ffd600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.26rem 1rem;
    background: transparent;
  }

  .landing-marquee__list li::after {
    content: "✦";
    margin-left: 1rem;
    color: #ff5c3a;
    opacity: 0.8;
  }

  @keyframes landing-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (max-width: 900px) {
    .landing-page :global(.section-gap) {
      padding-block: clamp(1.25rem, 5vw, 1.8rem);
    }
  }

  /* Suppress the global CSS dot grid — rough canvas replaces it */
  :global(body)::before {
    content: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-marquee__track {
      animation: none;
      transform: translateX(0);
    }

    #rough-bg-canvas {
      display: none;
    }
  }
</style>
