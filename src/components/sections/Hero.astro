---
import MarvinBot from "../islands/MarvinBot.svelte";
import { SITE } from "../../lib/constants";

const TITLES = [
  "Business Analyst",
  "Technical Generalist",
  "Product Engineer",
  "Data Specialist",
];
---

<section class="hero section-gap" aria-label="Introduction">
  <div class="container">
    <div class="hero__content">
      <div class="hero__text">
        <p class="hero__greeting">
          <span class="hero__greeting-line">Hi, I'm</span>
        </p>
        <h1 class="hero__name" id="hero-name">
          <span class="gradient-text">{SITE.author}</span>
        </h1>
        <p class="hero__title">
          <span
            class="hero__title-text"
            id="hero-title"
            data-titles={JSON.stringify(TITLES)}></span>
        </p>
        <p class="hero__pitch">
          I transform complex data into <strong>actionable insights</strong>
          and drive strategic decision-making. UBC MBAN candidate with
          experience in wealth management analytics, data visualization,
          and cross-functional collaboration.
        </p>

        <div class="hero__sticker">Available for work ✦</div>

      </div>

      <div class="hero__deco" aria-hidden="true">
        <MarvinBot client:load />
      </div>
    </div>
  </div>
</section>

<script>
  // Typewriter effect that cycles through titles with backspace
  function initTypewriter() {
    const existingCleanup = (window as Window & { __heroTypeCleanup?: () => void })
      .__heroTypeCleanup;
    if (existingCleanup) existingCleanup();

    const el = document.querySelector("#hero-title") as HTMLElement;
    if (!el) return;

    const titles = JSON.parse(el.dataset.titles || '["Business Analyst"]');
    let titleIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    let isPaused = false;
    let timeoutId: number | undefined;

    const longestTitleLength = titles.reduce(
      (max: number, title: string) => Math.max(max, title.length),
      0,
    );
    el.style.minWidth = `${longestTitleLength}ch`;

    const type = () => {
      const currentTitle = titles[titleIndex];

      if (isPaused) {
        isPaused = false;
        timeoutId = window.setTimeout(() => {
          isDeleting = true;
          type();
        }, 2000);
        return;
      }

      if (isDeleting) {
        el.textContent = currentTitle.substring(0, charIndex - 1);
        charIndex--;

        if (charIndex === 0) {
          isDeleting = false;
          titleIndex = (titleIndex + 1) % titles.length;
          timeoutId = window.setTimeout(type, 300);
        } else {
          timeoutId = window.setTimeout(type, 40);
        }
      } else {
        el.textContent = currentTitle.substring(0, charIndex + 1);
        charIndex++;

        if (charIndex === currentTitle.length) {
          isPaused = true;
          timeoutId = window.setTimeout(type, 500);
        } else {
          timeoutId = window.setTimeout(type, 80 + Math.random() * 40);
        }
      }
    };

    timeoutId = window.setTimeout(type, 500);

    (window as Window & { __heroTypeCleanup?: () => void }).__heroTypeCleanup = () => {
      if (timeoutId) window.clearTimeout(timeoutId);
    };
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTypewriter);
  } else {
    initTypewriter();
  }

  document.addEventListener("astro:page-load", initTypewriter);
  document.addEventListener("astro:before-swap", () => {
    (window as Window & { __heroTypeCleanup?: () => void }).__heroTypeCleanup?.();
  });
</script>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Playfair+Display:wght@900&display=swap");

  .hero {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-block: clamp(0.5rem, 2vw, 1.25rem) clamp(0.75rem, 2vw, 1.5rem);
  }

  /* ── Sticker ── */
  .hero__sticker {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.9rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    background: #ffd600;
    border: 2px solid #0d0d12;
    box-shadow: 3px 3px 0 #0d0d12;
    margin-top: var(--space-md);
    width: fit-content;
    color: #0d0d12;
  }

  :global([data-theme="dark"]) .hero__sticker {
    background: #e6c000;
  }

  .hero__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    position: relative;
    z-index: 1;
  }

  .hero__text {
    max-width: 600px;
    animation: fade-up 0.8s ease-out;
    flex: 1;
  }

  .hero__greeting {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .hero__name {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(2.8rem, 7vw, 5.6rem);
    font-weight: 900;
    margin-bottom: var(--space-sm);
    line-height: 0.96;
    letter-spacing: -0.03em;
  }

  .hero__title {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 2vw, 1.2rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    min-height: 1.7em;
  }

  .hero__title-text {
    display: inline-block;
    position: relative;
    color: #0d0d12;
    white-space: nowrap;
    font-weight: 700;
  }

  :global([data-theme="dark"]) .hero__title-text {
    color: #f5f5f5;
  }

  .hero__title-text::after {
    content: "|";
    margin-left: 0.08em;
    color: #ffd600;
    font-weight: 600;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .hero__pitch {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.8vw, 1.18rem);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-md);
    max-width: 50ch;
  }

  .hero__pitch strong {
    color: var(--color-text);
    font-weight: 700;
  }

  .hero__deco {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 340px;
    padding-top: 20px;
  }

  /* Desktop: side by side */
  @media (min-width: 901px) {
    .hero__content {
      flex-direction: row;
    }
  }

  /* Mobile: text-first layout, hide MarvinBot */
  @media (max-width: 900px) {
    .hero__content {
      flex-direction: column;
      text-align: center;
      gap: var(--space-md);
      padding-block: var(--space-lg);
    }

    .hero__text {
      order: 1;
      max-width: 100%;
    }

    .hero__pitch {
      max-width: none;
      margin-inline: auto;
    }

    .hero__title {
      justify-content: center;
    }

    .hero__deco {
      display: none;
    }

    .hero__sticker {
      margin-inline: auto;
    }
  }

  @media (max-width: 640px) {
    .hero__title {
      font-size: 0.92rem;
      justify-content: center;
    }
  }
</style>
