---
import SectionHeader from "../ui/SectionHeader.astro";
import SketchHighlight from "../sketch/SketchHighlight.astro";
import { EXPERIENCES } from "../../lib/constants";

const LOGO_FILES: Record<string, string> = {
  ubc: "/logos/UBC.png",
  goldman: "/logos/Goldman.jpeg",
  megaplex: "/logos/megaplex.jpeg",
};

const totalCards = EXPERIENCES.length;
---

<section class="experience section-gap" id="experience" aria-label="Experience">
  <div class="container">
    <SectionHeader title="Experience" subtitle="Where I've worked." />

    <div
      class="experience-stack"
      style={`--stack-count: ${totalCards};`}
      data-experience-stack
      aria-label="Experience stack"
    >
      {
        EXPERIENCES.map((exp, index) => (
          <article
            class={`sketch-card experience-card${index === 0 ? " is-focused" : ""}`}
            style={`--hover-accent: ${exp.accentColor || "var(--color-accent)"}; --stack-index: ${index}; --stack-z: ${totalCards - index};`}
            data-stack-card
          >
            <div class="sketch-card__accent" aria-hidden="true"></div>
            <div class="experience-card__content">
              <div class="experience-card__header">
                <div class="experience-card__title-group">
                  <h3 class="experience-card__role">
                    {exp.current ? <SketchHighlight>{exp.role}</SketchHighlight> : exp.role}
                  </h3>
                  <div class="experience-card__company-row">
                    {exp.logo && (
                      <span class="experience-card__logo-wrapper">
                        <img
                          src={LOGO_FILES[exp.logo]}
                          alt=""
                          class="experience-card__logo"
                          width="34"
                          height="34"
                        />
                      </span>
                    )}
                    <p class="experience-card__company">{exp.company}</p>
                  </div>
                </div>
                <span class="experience-card__period">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                  </svg>
                  {exp.period}
                </span>
              </div>

              <p class="experience-card__desc">{exp.description}</p>

              <ul class="experience-card__highlights">
                {exp.highlights.map((highlight) => (
                  <li class="experience-card__highlight">
                    <span class="highlight__bullet" />
                    {highlight}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .experience :global(.section-header) {
    margin-bottom: var(--space-lg);
  }

  .experience.section-gap {
    padding-bottom: 0;
  }

  /* Prevent global sketch-card hover transform from fighting the JS stack */
  .experience-card,
  .experience-card:hover {
    transform: none !important;
    cursor: pointer;
  }

  .experience-stack {
    position: relative;
    max-width: 800px;
    margin-inline: auto;
    height: calc((var(--stack-count) - 1) * 140px + 340px);
  }

  .experience-card {
    position: absolute;
    left: 0;
    right: 0;
    top: calc((var(--stack-count) - 1 - var(--stack-index)) * 140px);
    z-index: var(--stack-z);
    padding: var(--space-md);
    background: var(--color-surface);
    /* no max-height — card extends to natural height, lower portion hidden by higher z-index card */
    box-shadow: none;
    transition:
      top 300ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 300ms ease,
      left 300ms cubic-bezier(0.4, 0, 0.2, 1),
      right 300ms cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }

  .experience-card.is-focused {
    top: calc((var(--stack-count) - 1) * 140px);
    z-index: 30;
    box-shadow: 8px 8px 0 var(--color-stroke);
    opacity: 1;
  }

  .experience-card__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .experience-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .experience-card__title-group {
    flex: 1;
    min-width: 0;
  }

  .experience-card__role {
    font-family: var(--font-hand);
    font-size: var(--text-xl);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
  }

  .experience-card__company-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .experience-card__logo-wrapper {
    width: 34px;
    height: 34px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: 4px;
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .experience-card__logo {
    width: 34px;
    height: 34px;
    object-fit: contain;
    display: block;
  }

  .experience-card__company {
    font-family: var(--font-hand);
    font-size: var(--text-lg);
    color: var(--hover-accent, var(--color-accent));
    font-weight: 600;
    line-height: 1.35;
  }

  .experience-card__period {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    background: var(--color-bg);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-stroke-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .experience-card__desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: var(--space-xs);
  }

  .experience-card__highlights {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .experience-card__highlight {
    display: flex;
    align-items: flex-start;
    gap: 0.6em;
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.55;
    transition: all 0.15s ease;
    padding: var(--space-xs);
    border-radius: var(--radius-sm);
  }

  .experience-card__highlight:hover {
    background: var(--color-bg);
    color: var(--hover-accent, var(--color-accent));
  }

  .highlight__bullet {
    flex-shrink: 0;
    margin-top: 0.44em;
    width: 8px;
    height: 8px;
    background: var(--hover-accent, var(--color-accent));
    border-radius: 50%;
    filter: url(#sketch-filter);
    transition: transform 0.15s ease;
  }

  .experience-card__highlight:hover .highlight__bullet {
    transform: scale(1.2);
  }

  @media (max-width: 900px) {
    .experience :global(.section-header) {
      margin-bottom: var(--space-md);
    }

    .experience-stack {
      height: auto;
      display: grid;
      gap: var(--space-md);
    }

    .experience-card,
    .experience-card.is-focused {
      position: relative;
      left: auto;
      right: auto;
      top: auto;
      z-index: auto;
      box-shadow: none;
      opacity: 1;
    }

    .experience-card,
    .experience-card:hover {
      cursor: default;
    }

    .experience-card__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .experience-card__role {
      font-size: var(--text-lg);
    }

    .experience-card__company {
      font-size: var(--text-base);
    }

    .experience-card__desc,
    .experience-card__highlight {
      font-size: var(--text-sm);
    }
  }
</style>

<script>
  function initExperienceStack() {
    (window as Window & { __experienceStackCleanup?: () => void }).__experienceStackCleanup?.();

    const stack = document.querySelector("[data-experience-stack]") as HTMLElement | null;
    if (!stack) return;

    const cards = Array.from(stack.querySelectorAll("[data-stack-card]")) as HTMLElement[];
    if (cards.length === 0) return;

    const mobileQuery = window.matchMedia("(max-width: 900px)");
    const PEEK_H = 140;
    const n = cards.length;
    const clickHandlers = new Map<HTMLElement, () => void>();
    let isDesktopBound = false;

    const activate = (target: HTMLElement) => {
      const targetIdx = cards.indexOf(target);
      cards.forEach((card, i) => {
        const isActive = i === targetIdx;
        card.classList.toggle("is-focused", isActive);
        if (isActive) {
          card.style.top = `${(n - 1) * PEEK_H}px`;
          card.style.zIndex = "30";
          card.style.opacity = "1";
          card.style.left = "0px";
          card.style.right = "0px";
        } else {
          const slot = (n - 1 - i) - (targetIdx > i ? 1 : 0);
          card.style.top = `${slot * PEEK_H}px`;
          // higher slot = lower in viewport = higher z-index, so it covers the card above it
          card.style.zIndex = String(slot + 2);
          const shrink = (n - 1) - slot;
          const inset = `${shrink * 4}%`;
          card.style.left = inset;
          card.style.right = inset;
          card.style.opacity = "1";
        }
      });
    };

    const clearDesktopInlineStyles = () => {
      cards.forEach((card, index) => {
        card.classList.toggle("is-focused", index === 0);
        card.style.removeProperty("top");
        card.style.removeProperty("left");
        card.style.removeProperty("right");
        card.style.removeProperty("z-index");
        card.style.removeProperty("opacity");
      });
    };

    const bindDesktopInteractions = () => {
      if (isDesktopBound) return;
      cards.forEach((card) => {
        const clickHandler = () => activate(card);
        clickHandlers.set(card, clickHandler);
        card.addEventListener("click", clickHandler);
      });
      isDesktopBound = true;
    };

    const unbindDesktopInteractions = () => {
      if (!isDesktopBound) return;
      cards.forEach((card) => {
        const clickHandler = clickHandlers.get(card);
        if (clickHandler) card.removeEventListener("click", clickHandler);
      });
      clickHandlers.clear();
      isDesktopBound = false;
    };

    const syncForViewport = () => {
      if (mobileQuery.matches) {
        unbindDesktopInteractions();
        clearDesktopInlineStyles();
        return;
      }

      bindDesktopInteractions();
      activate(cards[0]);
    };

    syncForViewport();
    window.addEventListener("resize", syncForViewport);
    mobileQuery.addEventListener("change", syncForViewport);

    (window as Window & { __experienceStackCleanup?: () => void }).__experienceStackCleanup = () => {
      unbindDesktopInteractions();
      window.removeEventListener("resize", syncForViewport);
      mobileQuery.removeEventListener("change", syncForViewport);
    };
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initExperienceStack);
  } else {
    initExperienceStack();
  }

  document.addEventListener("astro:page-load", initExperienceStack);
  document.addEventListener("astro:before-swap", () => {
    (window as Window & { __experienceStackCleanup?: () => void }).__experienceStackCleanup?.();
  });
</script>
