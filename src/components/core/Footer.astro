---
import { SITE } from '../../lib/constants';
---

<footer class="footer">
  <div class="footer__content container">

    <div class="footer__main">
      <div class="footer__left">
        <p class="footer__overline">Open to opportunities</p>
        <h2 class="footer__headline">
          Let's build something <span class="footer__headline-outline">unforgettable.</span>
        </h2>
      </div>

      <div class="footer__right">
        <p class="footer__sub">
          Internships, full-time analytics roles, ambitious side projects — I'm in.
        </p>
        <div class="footer__links">
          {SITE.socialLinks.email && (
            <a href={SITE.socialLinks.email} class="footer__link footer__link--primary">
              Drop me a line →
            </a>
          )}
          {SITE.socialLinks.github && (
            <a href={SITE.socialLinks.github} target="_blank" rel="noopener" class="footer__link footer__link--ghost">
              GitHub ↗
            </a>
          )}
          {SITE.socialLinks.linkedin && (
            <a href={SITE.socialLinks.linkedin} target="_blank" rel="noopener" class="footer__link footer__link--ghost">
              LinkedIn ↗
            </a>
          )}
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <div class="footer__brand">
        <span class="footer__logo-block">RJ</span>
        <p class="footer__tagline">Data-driven insights &amp; analytics</p>
      </div>
      <p class="footer__copyright">
        &copy; {new Date().getFullYear()} {SITE.author} &mdash; Built with
        <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
        &amp;
        <a href="https://roughjs.com" target="_blank" rel="noopener">rough.js</a>
      </p>
    </div>

  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: rgba(255, 248, 220, 0.85);
    margin-top: auto;
  }

  .footer__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-top: var(--space-xl);
    padding-bottom: var(--space-md);
  }

  /* ── Main two-column row ── */
  .footer__main {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-xl);
    align-items: flex-start;
  }

  /* ── Left: overline + headline ── */
  .footer__overline {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(13, 13, 18, 0.55);
    margin: 0 0 var(--space-xs);
  }

  .footer__headline {
    font-family: var(--font-ui);
    font-size: clamp(1.6rem, 3.2vw, 2.6rem);
    font-weight: 900;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: #0d0d12;
    margin: 0;
  }

  .footer__headline-outline {
    -webkit-text-stroke: 2px #0d0d12;
    color: transparent;
  }

  /* ── Right: sub + links ── */
  .footer__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-top: 1.4rem;
  }

  .footer__sub {
    font-size: var(--text-base);
    color: rgba(13, 13, 18, 0.6);
    line-height: 1.6;
    margin: 0;
  }

  .footer__links {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .footer__link {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.2rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    border: 2px solid #0d0d12;
    box-shadow: 3px 3px 0 #0d0d12;
    transition: transform 140ms ease, box-shadow 140ms ease;
  }

  .footer__link:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 #0d0d12;
  }

  .footer__link--primary {
    background: #0d0d12;
    color: #ffd600;
  }

  .footer__link--ghost {
    background: transparent;
    color: #0d0d12;
  }

  /* ── Bottom row ── */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    padding-top: var(--space-md);
    border-top: 2px solid rgba(13, 13, 18, 0.18);
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer__logo-block {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    background: #0d0d12;
    color: #ffd600;
    font-family: var(--font-ui);
    font-weight: 900;
    font-size: 0.85rem;
    border-radius: 5px;
    flex-shrink: 0;
  }

  .footer__tagline {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: rgba(13, 13, 18, 0.5);
    margin: 0;
    letter-spacing: 0.04em;
  }

  .footer__copyright {
    font-size: var(--text-xs);
    color: rgba(13, 13, 18, 0.5);
    margin: 0;
  }

  .footer__copyright a {
    color: #0d0d12;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer__copyright a:hover {
    opacity: 0.65;
  }

  @media (max-width: 700px) {
    .footer__main {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
