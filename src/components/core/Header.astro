---
import ThemeToggle from "./ThemeToggle.astro";
import { UserMenu } from "../auth/UserMenu";
import { NAV_LINKS, CANVAS_NAV_LINKS } from "../../lib/constants";

const currentPath = Astro.url.pathname;
const hostname = Astro.url.hostname;

// Canvas-only mode: only true when on canvas.rohanjasani.com subdomain
// NOT when on main site at /ai-canvas
const isCanvasOnly =
  hostname === "canvas.rohanjasani.com" || hostname.startsWith("canvas.");

const links = isCanvasOnly ? CANVAS_NAV_LINKS : NAV_LINKS;
---

<header class="header">
  <nav class="header__nav container" aria-label="Main navigation">
    <a href="/" class="header__logo">
      <span class="header__logo-block">RJ</span>
    </a>

    <ul class="header__links" role="list">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "header__link",
                {
                  active:
                    currentPath === link.href ||
                    (link.href !== "/" && currentPath.startsWith(link.href)),
                },
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="header__actions">
      <UserMenu client:only="react" />
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background: rgba(var(--color-bg-rgb), 0.46);
    backdrop-filter: blur(14px) saturate(130%);
    -webkit-backdrop-filter: blur(14px) saturate(130%);
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-stroke-muted) 55%, transparent);
    box-shadow: 0 10px 24px -22px rgba(13, 13, 18, 0.32);
    transition:
      background 0.3s ease,
      box-shadow 0.3s ease;
  }

  .header__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-sm);
    gap: var(--space-md);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .header__logo {
    display: flex;
    align-items: center;
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.01em;
    position: relative;
    transition: transform 0.18s ease;
  }

  .header__logo:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .header__logo-block {
    display: grid;
    place-items: center;
    width: 2.15rem;
    height: 2.15rem;
    background: #0d0d12;
    color: #ffd600;
    border-radius: 0.38rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 800;
    line-height: 1;
    border: 2px solid #0d0d12;
    box-shadow: 2px 2px 0 rgba(13, 13, 18, 0.22);
  }

  .header__links {
    display: flex;
    gap: var(--space-xs);
    background: rgba(var(--color-bg-rgb), 0.5);
    padding: var(--space-xs);
    border-radius: var(--radius-lg);
    border: 1px solid
      color-mix(in srgb, var(--color-stroke-muted) 70%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .header__link {
    font-family: var(--font-hand);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
    position: relative;
  }

  .header__link:hover {
    color: var(--color-text);
    text-decoration: none;
    background: rgba(var(--color-bg-rgb), 0.58);
  }

  .header__link.active {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-fill-1) 74%, transparent);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .header__nav {
      padding-block: var(--space-xs);
    }

    .header__links {
      gap: 0;
    }

    .header__link {
      font-size: var(--text-xs);
      padding: var(--space-2xs) var(--space-xs);
    }

    .header__actions {
      gap: var(--space-xs);
    }
  }
</style>
