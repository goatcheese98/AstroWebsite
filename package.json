{
  "name": "astroweb",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "astro dev",
    "dev:canvas": "astro dev",
    "dev:all": "bunx concurrently \"astro dev\" \"bunx partykit dev\"",
    "dev:preview": "bun run build && bunx wrangler pages dev dist --port=4321",
    "dev:party": "bunx partykit dev",
    "build": "astro build",
    "build:fast": "bun run scripts/build-fast.js",
    "build:bun:fast": "bun run build:fast",
    "build:canvas": "bun run scripts/build-canvas.js prepare && DEPLOY_TARGET=canvas astro build && bun run scripts/build-canvas.js restore",
    "preview": "astro preview",
    "preview:canvas": "DEPLOY_TARGET=canvas astro preview",
    "deploy": "bun run deploy:web",
    "deploy:web": "bun run build && bunx wrangler pages deploy dist --project-name=astroweb",
    "deploy:canvas": "bun run build:canvas && bunx wrangler pages deploy dist --project-name=ai-canvas",
    "astro": "astro",
    "test": "bunx vitest run --passWithNoTests"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/svelte": "^7.2.5",
    "@clerk/astro": "^2.17.1",
    "@clerk/clerk-react": "^5.60.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@excalidraw/mermaid-to-excalidraw": "^2.0.0",
    "@google/generative-ai": "^0.24.1",
    "@lexical/code": "^0.40.0",
    "@lexical/link": "^0.40.0",
    "@lexical/list": "^0.40.0",
    "@lexical/markdown": "^0.40.0",
    "@lexical/react": "^0.40.0",
    "@lexical/rich-text": "^0.40.0",
    "@lexical/selection": "^0.40.0",
    "@lexical/table": "^0.40.0",
    "@lexical/utils": "^0.40.0",
    "@msgpack/msgpack": "^3.1.3",
    "@terrastruct/d2": "^0.1.33",
    "@types/katex": "^0.16.8",
    "@types/react-syntax-highlighter": "^15.5.13",
    "astro": "^5.16.15",
    "drizzle-orm": "^0.45.1",
    "html2canvas": "^1.4.1",
    "katex": "^0.16.28",
    "lexical": "^0.40.0",
    "nanoid": "^5.1.6",
    "partykit": "^0.0.115",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "rough-notation": "^0.5.1",
    "roughjs": "^4.6.4",
    "svelte": "^5.49.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "vitest": "^4.0.18"
  },
  "trustedDependencies": [
    "@clerk/shared",
    "browser-tabs-lock",
    "core-js"
  ]
}
